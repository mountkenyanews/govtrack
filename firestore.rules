rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /server_db/{nodeId} {
      allow read: if resource.data.is_server_node == true;
      allow create: if request.resource.data.is_server_node == true;
      allow update: if request.resource.data.is_server_node == true && request.resource.data.server_secret == resource.data.server_secret;
    }
  }
}
