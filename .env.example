# =========================================================================
# 🏛️ GOVTRACK GLOBAL PLATFORM CONFIGURATION (TEMPLATE)
# =========================================================================

# Global Node Settings
NODE_ENV="production"
PORT="3000"
APP_URL="https://govtrack.co.ke"

# =========================================================================
# ⚙️ AIVEN POSTGRESQL DATABASE PERSISTENCE
# =========================================================================
# Connection URI from console.aiven.io (e.g. postgres://avnadmin:password@host:port/defaultdb?sslmode=require)
DATABASE_URL="postgres://avnadmin:password@host:port/defaultdb?sslmode=require"

# =========================================================================
# 🧠 AI ENGINES: GROQ (PRIMARY) & GOOGLE GEMINI (RESILIENT FALLBACK)
# =========================================================================
# Primary AI Engine API Key from console.groq.com
GROQ_API_KEY=""

# Resilient Fallback AI Engine API Key from console.google.com
GEMINI_API_KEY=""
